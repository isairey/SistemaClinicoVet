<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerSeeNotifications.NotificationsSee"
            prefHeight="1000.0" prefWidth="992.0"
            style="-fx-background-color:#DFD6D6;">

    <!-- ===== Barra superior: logo + (campana / perfil) ===== -->
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="10"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <ImageView fx:id="topLogo" onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- ===== Menú superior ===== -->
    <HBox alignment="CENTER" prefHeight="100.0" spacing="32"
          style="-fx-background-color:#113051;"
          AnchorPane.topAnchor="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos" onAction="#onRegistrarProductos"
                prefHeight="36.0" minWidth="160.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario" onAction="#onInventario"
                prefHeight="36.0" minWidth="130.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnGestionarUsuario" text="Gestionar Usuario" onAction="#onGestionarUsuario"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistros" text="Visualizar Registros" onAction="#onVisualizarRegistros"
                prefHeight="36.0" minWidth="165.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentas" text="Ventas" onAction="#onVentas"
                prefHeight="36.0" minWidth="110.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientes" text="Agregar Clientes" onAction="#onAgregarClientes"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedores" text="Administrar Proveedores" onAction="#onAdministrarProveedores"
                prefHeight="36.0" minWidth="200.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- ===== Card central ===== -->
    <AnchorPane AnchorPane.topAnchor="205.0" AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0" AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="12" right="18" bottom="12" left="18"/></padding>

        <!-- fila superior: Volver -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <Button fx:id="btnVolver" text="Volver"
                    onAction="#onVolver"
                    style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:6 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox spacing="18"
              AnchorPane.topAnchor="38.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

            <!-- Título -->
            <VBox spacing="6" alignment="CENTER" mouseTransparent="true">
                <Label text="Notificaciones"
                       style="-fx-text-fill:#E9EEF3; -fx-font-size:32px; -fx-font-weight:bold;"/>
                <Label text="Aquí puedes consultar las notificaciones del sistema."
                       wrapText="true"
                       style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;"/>
            </VBox>

            <!-- Tarjeta blanca con la tabla de notificaciones -->
            <AnchorPane style="-fx-background-color:#FFFFFF; -fx-background-radius:14; -fx-padding:16;">
                <ScrollPane fx:id="scrollTabla"
                            fitToWidth="false" fitToHeight="true"
                            vbarPolicy="ALWAYS" hbarPolicy="ALWAYS"
                            style="-fx-background-color:transparent; -fx-background-insets:0;"
                            AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                            AnchorPane.bottomAnchor="52.0">
                    <content>
                        <!-- Wrapper y Table con el MISMO ancho que la suma de columnas -->
                        <VBox fx:id="tableWrapper" spacing="8" style="-fx-background-color:white;" prefWidth="1995.0">
                            <TableView fx:id="tblNotificaciones" prefHeight="560.0" prefWidth="1995.0"
                                       style="-fx-font-size:14px; -fx-table-cell-border-color:#D7DBE2; -fx-padding:0; -fx-background-radius:10; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                                <columns>
                                    <TableColumn fx:id="colFecha"   text="Fecha/Hora" prefWidth="300.0"/>
                                    <TableColumn fx:id="colTipo"    text="Tipo"       prefWidth="300.0"/>
                                    <TableColumn fx:id="colMensaje" text="Mensaje"    prefWidth="990.0"/>
                                    <TableColumn fx:id="colModulo"  text="Módulo"     prefWidth="400.0"/>
                                </columns>
                                <placeholder>
                                    <Label text="Sin notificaciones por el momento."
                                           style="-fx-text-fill:#607489; -fx-font-size:13px;"/>
                                </placeholder>
                            </TableView>

                            <Label text="Consejo: usa Buscar para filtrar por texto o tipo. Selecciona una fila para Eliminar."
                                   style="-fx-text-fill:#6A7C90; -fx-font-size:12px; -fx-padding:6 2 0 2;"/>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Botonera inferior derecha -->
                <HBox spacing="12" alignment="CENTER_RIGHT"
                      AnchorPane.rightAnchor="8.0" AnchorPane.bottomAnchor="8.0">
                    <Button fx:id="btnDeshacer" text="Deshacer" onAction="#onDeshacer"
                            style="-fx-background-color:#7A91A7; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                    <Button fx:id="btnEditar" text="Editar" onAction="#onEditar"
                            style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                    <Button fx:id="btnEliminar" text="Eliminar" onAction="#onEliminar"
                            style="-fx-background-color:#E45858; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                </HBox>
            </AnchorPane>
        </VBox>
    </AnchorPane>
</AnchorPane>
