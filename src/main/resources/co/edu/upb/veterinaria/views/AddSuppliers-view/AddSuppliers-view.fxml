<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllersAddSuppliers.SuppliersAdd"
            prefHeight="1000.0" prefWidth="992.0"
            style="-fx-background-color:#DFD6D6;">

    <!-- Barra superior con logo + menús (campana / perfil) -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          prefHeight="70.0"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <!-- Logo: vuelve al Main Menu -->
        <ImageView fx:id="topLogo"
                   onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0" preserveRatio="true" pickOnBounds="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Campana (notificaciones) -->
        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <!-- Perfil (datos personales / cerrar sesión) -->
        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- Menú superior -->
    <HBox alignment="CENTER" spacing="32"
          layoutY="70.0" prefHeight="100.0"
          style="-fx-background-color:#113051;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos" onAction="#onRegistrarProductos"
                prefHeight="36.0" minWidth="160.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario" onAction="#onInventario"
                prefHeight="36.0" minWidth="130.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnGestionarUsuario" text="Gestionar Usuario" onAction="#onGestionarUsuario"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistros" text="Visualizar Registros" onAction="#onVisualizarRegistros"
                prefHeight="36.0" minWidth="165.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentas" text="Ventas" onAction="#onVentas"
                prefHeight="36.0" minWidth="110.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientes" text="Agregar Clientes" onAction="#onAgregarClientes"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedores" text="Administrar Proveedores" onAction="#onAdministrarProveedores"
                prefHeight="36.0" minWidth="200.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- Panel central -->
    <AnchorPane AnchorPane.topAnchor="205.0"
                AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0"
                AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="26" right="26" bottom="26" left="26"/></padding>

        <StackPane AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
            <VBox spacing="24" maxWidth="1400.0" prefWidth="1400.0" StackPane.alignment="TOP_CENTER">

                <!-- Título y descripción -->
                <VBox spacing="6" alignment="CENTER">
                    <Label text="Agregar Proveedores"
                           style="-fx-text-fill:#E9EEF3; -fx-font-size:32px; -fx-font-weight:bold;"/>
                    <Label text="En este módulo se registran los proveedores que realizan importaciones a la veterinaria y la información que se deben guardar de estas."
                           wrapText="true"
                           style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;"/>
                </VBox>

                <!-- Formulario (dos columnas) + Tarjeta derecha -->
                <GridPane hgap="28" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="36"/>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="36"/>
                        <ColumnConstraints percentWidth="20"/>
                    </columnConstraints>

                    <!-- Fila 0 -->
                    <Label text="Tipo persona :" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbTipoProveedor" promptText="Seleccione"
                              prefHeight="28.0"
                              style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                              GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Tipo documento:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbTipoDocumento" promptText="Seleccione"
                              prefHeight="28.0"
                              style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                              GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                    <!-- Fila 1 -->
                    <Label text="Nombre:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfNombre" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Apellido:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfApellido" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                    <!-- Fila 2 -->
                    <Label text="Dirección:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="tfDireccion" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Ciudad:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    <TextField fx:id="tfCiudad" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                    <!-- Fila 3 -->
                    <Label text="NIT:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="tfNIT" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Email:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                    <TextField fx:id="tfEmail" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                    <!-- Fila 4 -->
                    <Label text="Teléfono:" style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="tfTelefono" prefHeight="28.0"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <!-- Fila 5: Guardar (ANTES era la 6) -->
                    <HBox alignment="CENTER_RIGHT"
                          GridPane.columnIndex="1" GridPane.rowIndex="5" GridPane.columnSpan="3">
                        <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar"
                                prefHeight="50.0" minWidth="200.0"
                                style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 18;"/>
                    </HBox>

                    <!-- Tarjeta derecha (rowSpan reducido de 7 a 6) -->
                    <AnchorPane GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.rowSpan="6"
                                style="-fx-background-color:#E6DEDE; -fx-background-radius:12;">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <VBox spacing="22" alignment="CENTER"
                              AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
                              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
                            <Label text="Aquí puede acceder a poder ver la información de los proveedores ya registrados:"
                                   wrapText="true"
                                   style="-fx-text-fill:#1F2D3C; -fx-font-size:16px; -fx-font-weight:bold;"/>
                            <Button fx:id="btnVerProveedores" text="Entrar" onAction="#onVerProveedores"
                                    prefHeight="46.0" minWidth="160.0"
                                    style="-fx-background-color:#FFFFFF; -fx-text-fill:#1F2D3C; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 18;"/>
                        </VBox>
                    </AnchorPane>
                </GridPane>

            </VBox>
        </StackPane>
    </AnchorPane>
</AnchorPane>