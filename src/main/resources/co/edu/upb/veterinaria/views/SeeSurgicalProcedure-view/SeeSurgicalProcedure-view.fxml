<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerSeeSurgicalProcedure.SurgicalProcedureSee"
            prefHeight="1000.0" prefWidth="992.0"
            style="-fx-background-color:#DFD6D6;">

    <!-- Barra superior con logo + (campana / perfil) -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          prefHeight="70.0"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <!-- Logo -> MainMenu -->
        <ImageView fx:id="topLogo" onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0" preserveRatio="true" pickOnBounds="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Campana (notificaciones) -->
        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <!-- Perfil (datos personales / cerrar sesión) -->
        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- Menú superior -->
    <HBox alignment="CENTER" spacing="32"
          layoutY="70.0" prefHeight="100.0"
          style="-fx-background-color:#113051;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos" onAction="#onRegistrarProductos"
                prefHeight="36.0" minWidth="160.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario" onAction="#onInventario"
                prefHeight="36.0" minWidth="130.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnGestionarUsuario" text="Gestionar Usuario" onAction="#onGestionarUsuario"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistrosTop" text="Visualizar Registros" onAction="#onVisualizarRegistrosTop"
                prefHeight="36.0" minWidth="165.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentasTop" text="Ventas" onAction="#onVentasTop"
                prefHeight="36.0" minWidth="110.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientesTop" text="Agregar Clientes" onAction="#onAgregarClientesTop"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedoresTop" text="Administrar Proveedores" onAction="#onAdministrarProveedoresTop"
                prefHeight="36.0" minWidth="200.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- Panel central -->
    <AnchorPane AnchorPane.topAnchor="205.0"
                AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0"
                AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="0" right="22" bottom="0" left="22"/></padding>

        <!-- Encabezado con Volver -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              AnchorPane.topAnchor="14.0" AnchorPane.leftAnchor="18.0" AnchorPane.rightAnchor="18.0">
            <Button fx:id="btnVolver" text="Volver" onAction="#onVolver"
                    style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:6 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox spacing="22"
              AnchorPane.topAnchor="54.0" AnchorPane.leftAnchor="18.0"
              AnchorPane.rightAnchor="18.0" AnchorPane.bottomAnchor="18.0">

            <!-- Título -->
            <VBox spacing="8" alignment="CENTER">
                <Label text="Historial Clínico"
                       style="-fx-text-fill:#E9EEF3; -fx-font-size:32px; -fx-font-weight:bold;"/>
                <Label text="Aquí puedes consultar el historial de la mascota, incluyendo los servicios que se le han realizado con su descripción."
                       wrapText="true"
                       style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;"/>
            </VBox>

            <!-- Tarjeta de contenido -->
            <AnchorPane style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:18;">

                <!-- Cabecera pequeña con cliente/mascota -->
                <HBox spacing="18" alignment="CENTER_LEFT"
                      AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <HBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color:#EDEDED; -fx-background-radius:10; -fx-padding:10 14; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                        <Label text="Cliente:" style="-fx-text-fill:#1F2D3C; -fx-font-weight:bold;"/>
                        <Label fx:id="lbCliente" text="N/A" style="-fx-text-fill:#1F2D3C;"/>
                        <Label text="   Mascota:" style="-fx-text-fill:#1F2D3C; -fx-font-weight:bold;"/>
                        <Label fx:id="lbMascota" text="N/A" style="-fx-text-fill:#1F2D3C;"/>
                    </HBox>
                </HBox>

                <!-- Tabla con scroll vertical y horizontal -->
                <ScrollPane fx:id="scrollTabla"
                            fitToWidth="false" fitToHeight="true"
                            vbarPolicy="ALWAYS" hbarPolicy="ALWAYS"
                            style="-fx-background-color:transparent; -fx-background-insets:0;"
                            AnchorPane.topAnchor="56.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                            AnchorPane.bottomAnchor="240.0">
                    <content>
                        <VBox fx:id="tableWrapper" spacing="10" style="-fx-background-color:white;" prefWidth="2000.0">
                            <TableView fx:id="tblServicios"
                                       prefHeight="520.0" prefWidth="1500.0"
                                       style="-fx-font-size:14px; -fx-table-cell-border-color:#D7DBE2; -fx-padding:2; -fx-background-radius:10; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                                <columns>
                                    <TableColumn fx:id="colIdServicio"        text="ID"                   prefWidth="200.0"/>
                                    <TableColumn fx:id="colNombreServicio"    text="Nombre del servicio"  prefWidth="500.0"/>
                                    <TableColumn fx:id="colPrecio"            text="Precio"               prefWidth="590.0"/>
                                    <TableColumn fx:id="colDescripcion"       text="Descripción"          prefWidth="700.0"/>
                                </columns>
                                <placeholder>
                                    <Label text="Sin servicios registrados para esta mascota."
                                           style="-fx-text-fill:#607489; -fx-font-size:13px;"/>
                                </placeholder>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Observaciones Adicionales -->
                <VBox spacing="10"
                      AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="72.0">
                    <Label text="Observaciones Adicionales"
                           style="-fx-text-fill:#1F2D3C; -fx-font-size:14px; -fx-font-weight:bold;"/>
                    <TextArea fx:id="taDescripcion" promptText="Aquí va las observaciones Adicionales…"
                              wrapText="true" prefRowCount="6"
                              style="-fx-background-color:#FFFFFF; -fx-background-radius:0; -fx-padding:0;"/>
                </VBox>

                <!-- Botonera inferior derecha -->
                <HBox spacing="14" alignment="CENTER_RIGHT"
                      AnchorPane.rightAnchor="6.0" AnchorPane.bottomAnchor="10.0">
                    <Button fx:id="btnDeshacer" text="Deshacer" onAction="#onDeshacer"
                            style="-fx-background-color:#7A91A7; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:8 16; -fx-font-size:12px;"/>
                    <Button fx:id="btnEditar" text="Editar" onAction="#onEditar"
                            style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:8 16; -fx-font-size:12px;"/>
                    <Button fx:id="btnEliminar" text="Eliminar" onAction="#onEliminar"
                            style="-fx-background-color:#E45858; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:8 16; -fx-font-size:12px;"/>
                </HBox>
            </AnchorPane>
        </VBox>
    </AnchorPane>
</AnchorPane>