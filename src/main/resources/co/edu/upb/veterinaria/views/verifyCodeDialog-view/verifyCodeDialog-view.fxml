<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/24.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="co.edu.upb.veterinaria.controllers.ControllerverifyCodeDialog.CodeDialogverify"
           style="-fx-background-color: transparent;">

            <!-- Tarjeta -->
            <VBox spacing="16" alignment="CENTER"
                  maxWidth="420"
                  style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 18, 0.2, 0, 8);">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <Label text="Verifique su correo"
                       style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill:#222;"/>

                <Label text="Por favor ingrese el código de 6 dígitos enviado a"
                       style="-fx-text-fill:#555; -fx-font-size: 13px;"/>
                <Label fx:id="lbEmail" text="someone@example.com"
                       style="-fx-text-fill:#777; -fx-font-size: 13px;"/>

                <!-- Celdas de código -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="tf1" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                    <TextField fx:id="tf2" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                    <TextField fx:id="tf3" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                    <TextField fx:id="tf4" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                    <TextField fx:id="tf5" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                    <TextField fx:id="tf6" prefWidth="42" prefHeight="42"
                               style="-fx-alignment: center; -fx-font-size:18px; -fx-background-radius:10;"/>
                </HBox>

                <!-- Error -->
                <Label fx:id="lbError" text="Porfavor ingrese un código de 6 digitos."
                       visible="false" managed="false"
                       style="-fx-text-fill:#c0392b; -fx-font-size:12px;"/>

                <!-- Botón confirmar -->
                <Button fx:id="btnConfirm" text="Confirmar" onAction="#onConfirm"
                        prefHeight="44" maxWidth="260"
                        style="-fx-background-color:#1BD0CF; -fx-text-fill:white; -fx-font-weight:800; -fx-background-radius:12; -fx-cursor:hand;"/>
            </VBox>
</StackPane>