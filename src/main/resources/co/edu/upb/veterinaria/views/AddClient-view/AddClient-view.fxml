<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerAddClient.ClientAdd"
            prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color:#DFD6D6;">

    <!-- ===== Barra superior: logo + (campana / perfil) ===== -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          prefHeight="70.0"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <!-- Logo (volver al menú) -->
        <ImageView fx:id="topLogo"
                   onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0" preserveRatio="true" pickOnBounds="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Campana (notificaciones) -->
        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <!-- Perfil (datos personales / cerrar sesión) -->
        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- ===== Menú (7 módulos) ===== -->
    <HBox alignment="CENTER" spacing="72"
          prefHeight="100.0"
          style="-fx-background-color:#113051;"
          AnchorPane.topAnchor="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos" onAction="#onRegistrarProductos"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario" onAction="#onInventario"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnGestionarUsuario" text="Gestionar Usuario" onAction="#onGestionarUsuario"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistros" text="Visualizar Registros" onAction="#onVisualizarRegistros"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentas" text="Ventas" onAction="#onVentas"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientes" text="Agregar Clientes" onAction="#onAgregarClientes"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedores" text="Administrar Proveedores" onAction="#onAdministrarProveedores"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- ===== Card central (Opción A) ===== -->
    <AnchorPane AnchorPane.topAnchor="205.0"
                AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0"
                AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <VBox spacing="22"
              AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

            <!-- Título -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="Agregar Clientes"
                       style="-fx-text-fill:#E9EEF3; -fx-font-size:32px; -fx-font-weight:bold;"/>
                <Label text="Registra los datos del cliente y asigna sus mascotas."
                       style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;" wrapText="true"/>
            </VBox>

            <!-- FORM (izq) + MASCOTAS (der) -->
            <HBox spacing="24">

                <!-- Formulario del cliente -->
                <GridPane fx:id="gridCliente" hgap="22" vgap="12" HBox.hgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <Label text="Tipo Persona:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <ComboBox fx:id="cbTipoPersona" GridPane.rowIndex="0" GridPane.columnIndex="1"
                              promptText="Seleccione"
                              style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;" prefHeight="28.0"/>

                    <Label text="Tipo Documento:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <ComboBox fx:id="cbTipoDocumento" GridPane.rowIndex="1" GridPane.columnIndex="1"
                              promptText="Seleccione"
                              style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:4 10;" prefHeight="28.0"/>

                    <Label text="Número Documento:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfDocumento" GridPane.rowIndex="2" GridPane.columnIndex="1"
                               promptText="Documento"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Nombre:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfNombre" GridPane.rowIndex="3" GridPane.columnIndex="1"
                               promptText="Nombre(s)"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Apellidos:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfApellidos" GridPane.rowIndex="4" GridPane.columnIndex="1"
                               promptText="Apellidos"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Fecha Nacimiento:" GridPane.rowIndex="5" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <DatePicker fx:id="dpFechaNacimiento" GridPane.rowIndex="5" GridPane.columnIndex="1"
                                style="-fx-background-color:#BFC2C8; -fx-background-radius:10;"/>

                    <Label text="Ciudad:" GridPane.rowIndex="6" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfCiudad" GridPane.rowIndex="6" GridPane.columnIndex="1"
                               promptText="Ciudad"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Email:" GridPane.rowIndex="7" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfEmail" GridPane.rowIndex="7" GridPane.columnIndex="1"
                               promptText="correo@dominio.com"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Dirección:" GridPane.rowIndex="8" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfDireccion" GridPane.rowIndex="8" GridPane.columnIndex="1"
                               promptText="Calle, número, barrio"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Teléfono:" GridPane.rowIndex="9" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfTelefono" GridPane.rowIndex="9" GridPane.columnIndex="1"
                               promptText="Número de contacto"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Contacto Emergencia (Nombre):" GridPane.rowIndex="10" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfContactoNombre" GridPane.rowIndex="10" GridPane.columnIndex="1"
                               promptText="Nombre del contacto"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>

                    <Label text="Contacto Emergencia (Teléfono):" GridPane.rowIndex="11" GridPane.columnIndex="0"
                           style="-fx-text-fill:#D9E1E8; -fx-font-size:13px;"/>
                    <TextField fx:id="tfContactoTelefono" GridPane.rowIndex="11" GridPane.columnIndex="1"
                               promptText="Teléfono del contacto"
                               style="-fx-background-color:#BFC2C8; -fx-background-radius:10; -fx-padding:8 12;"/>
                </GridPane>

                <!-- Mascotas del cliente -->
                <VBox spacing="12" prefWidth="380" minWidth="320">
                    <Label text="Mascotas del cliente"
                           style="-fx-text-fill:#E9EEF3; -fx-font-size:16px; -fx-font-weight:bold;"/>

                    <StackPane style="-fx-background-color:#0F2740; -fx-background-radius:12; -fx-border-color:#2E3F52; -fx-border-radius:12; -fx-border-width:2;"
                               prefHeight="380.0">
                        <ListView fx:id="lstMascotas"
                                  style="-fx-control-inner-background:#0F2740; -fx-background-color:transparent; -fx-text-fill:white; -fx-background-insets:0;"
                                  prefHeight="360.0">
                            <placeholder>
                                <Label text="Sin mascotas asignadas aún"
                                       style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;"/>
                            </placeholder>
                        </ListView>
                    </StackPane>

                    <HBox spacing="10">
                        <Button fx:id="btnAsignarMascota" text="Asignar Mascota" onAction="#onAsignarMascota"
                                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 12;"/>
                        <Button fx:id="btnQuitarMascota" text="Quitar Selección" onAction="#onQuitarMascota"
                                style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 12;"/>
                    </HBox>

                    <Label text="Aquí aparecerán las mascotas asignadas al cliente."
                           style="-fx-text-fill:#B9C6D3; -fx-font-size:12px;"/>
                </VBox>
            </HBox>

            <!-- Botón Guardar -->
            <HBox alignment="BOTTOM_RIGHT">
                <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar"
                        prefHeight="54.0" minWidth="180.0"
                        style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-size:20px; -fx-font-weight:bold; -fx-background-radius:12; -fx-padding:8 20;"/>
            </HBox>
        </VBox>
    </AnchorPane>
</AnchorPane>
