<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            prefHeight="720.0"
            prefWidth="1200.0"
            style="-fx-background-color: #0f2740;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerRecoverPasswordPrueba.RecoverPasswordPrueba">

    <children>
        <!-- GRID 50% | 8px | 50% -->
        <GridPane hgap="0" vgap="0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                <ColumnConstraints maxWidth="8" minWidth="8" prefWidth="8" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>

            <!-- ===== IZQUIERDA (50%) ===== -->
            <StackPane fx:id="leftPane" GridPane.columnIndex="0"
                       style="-fx-background-color: #FFFFFF;">
                <children>
                    <!-- Imagen de fondo del lado izquierdo -->
                    <ImageView fx:id="leftImage"
                               fitWidth="1400.0" fitHeight="1400.0"
                               pickOnBounds="false" preserveRatio="false" smooth="true">
                        <image>
                            <Image url="@../../images/imagenRecuperar.png" />
                        </image>
                    </ImageView>
                </children>
            </StackPane>

            <!-- Divisor 8px fijo -->
            <Region GridPane.columnIndex="1" style="-fx-background-color: #0c2034;" />

            <!-- ===== DERECHA (50%) ===== -->
            <AnchorPane fx:id="rightPane" GridPane.columnIndex="2"
                        style="-fx-background-color: #0f2740;">

                <!-- Barra superior -->
                <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="12"
                      AnchorPane.leftAnchor="28.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <StackPane prefHeight="44" prefWidth="44"
                                   style="-fx-background-color: #1BD0CF; -fx-background-radius: 12; -fx-alignment: center;">
                            <children>
                                <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
                                    <image><Image url="@../../images/logoSecundario.png" /></image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <Label text="Veterinaria &amp; Spa SOS"
                               style="-fx-text-fill: #E8EDF3; -fx-font-size: 20px; -fx-font-weight: 700; -fx-font-family: 'Montserrat','Segoe UI',sans-serif;" />
                    </children>
                </HBox>

                <!-- Tarjeta recuperar contraseña -->
                <StackPane fx:id="cardWrapper"
                           AnchorPane.bottomAnchor="64.0" AnchorPane.leftAnchor="64.0"
                           AnchorPane.rightAnchor="64.0" AnchorPane.topAnchor="100.0">
                    <children>
                        <StackPane fx:id="card"
                                   maxWidth="620.0"
                                   style="-fx-background-color: #06142A; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 24, 0.18, 0, 8); -fx-alignment: CENTER_LEFT;">
                            <children>
                                <VBox fx:id="cardContent" alignment="TOP_LEFT" maxWidth="520.0" spacing="40">
                                    <children>
                                        <Label text="Recuperar Contraseña"
                                               style="-fx-text-fill: #E8EDF3; -fx-font-size: 38px; -fx-font-weight: 900; -fx-font-family: 'Montserrat','Segoe UI',sans-serif;" />

                                        <Label text="Ingresa la nueva contraseña con más de 8 caracteres."
                                               style="-fx-text-fill: #E8EDF3; -fx-opacity: 0.8; -fx-font-size: 18px; -fx-font-weight: 400;" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Nueva Contraseña"
                                                       style="-fx-text-fill: #C8CFD8; -fx-font-size: 18px; -fx-font-weight: 700;" />
                                                <PasswordField fx:id="txtNuevaPassword"
                                                               prefHeight="44.0" maxWidth="420.0" promptText="••••••••"
                                                               style="-fx-background-color: #E5DCDC; -fx-background-radius: 14; -fx-border-radius: 14; -fx-padding: 8 14 8 14; -fx-font-size: 16px; -fx-text-fill: #172033;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Confirmar Contraseña"
                                                       style="-fx-text-fill: #C8CFD8; -fx-font-size: 18px; -fx-font-weight: 700;" />
                                                <PasswordField fx:id="txtConfirmarPassword"
                                                               prefHeight="44.0" maxWidth="420.0" promptText="••••••••"
                                                               style="-fx-background-color: #E5DCDC; -fx-background-radius: 14; -fx-border-radius: 14; -fx-padding: 8 14 8 14; -fx-font-size: 16px; -fx-text-fill: #172033;" />
                                            </children>
                                        </VBox>

                                        <Button fx:id="btnActualizar"
                                                text="Actualizar" onAction="#onActualizar"
                                                maxWidth="420.0" prefHeight="56.0"
                                                style="-fx-background-color: #1BD0CF; -fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;" />
                                    </children>
                                    <padding><Insets bottom="36" left="36" right="36" top="30" /></padding>
                                </VBox>
                            </children>
                            <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>
                        </StackPane>
                    </children>
                </StackPane>
            </AnchorPane>
        </GridPane>
    </children>
</AnchorPane>