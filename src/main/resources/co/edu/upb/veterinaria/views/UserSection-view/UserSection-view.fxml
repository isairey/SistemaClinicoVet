<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root"
            prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color:#DFD6D6;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerUserSection.SectionUser">

    <!-- ===== Barra superior: logo + (campana / perfil) ===== -->
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="10"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <ImageView fx:id="topLogo"
                   onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0"
                   pickOnBounds="true" preserveRatio="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Campana (notificaciones) -->
        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <!-- Perfil (datos personales / cerrar sesión) -->
        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- ===== Menú superior (7 módulos) ===== -->
    <HBox alignment="CENTER" prefHeight="100.0" spacing="92"
          style="-fx-background-color:#113051;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos"
                onAction="#onRegistrarProductos"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario"
                onAction="#onInventario"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistros" text="Visualizar Registros"
                onAction="#onVisualizarRegistros"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentas" text="Ventas"
                onAction="#onVentas"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientes" text="Agregar Clientes"
                onAction="#onAgregarClientes"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedores" text="Administrar Proveedores"
                onAction="#onAdministrarProveedores"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- ===== Card central (Opción A) ===== -->
    <AnchorPane AnchorPane.topAnchor="205.0"
                AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0"
                AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <VBox spacing="18" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

            <!-- Título -->
            <Label text="Usuarios del Sistema"
                   style="-fx-text-fill:white; -fx-font-size:26px; -fx-font-weight:800;"/>

            <!-- Fila filtros -->
            <AnchorPane style="-fx-background-color:#3E566D; -fx-background-radius:12; -fx-padding:14;">
                <HBox spacing="12" alignment="CENTER_LEFT"
                      AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0">
                    <Label text="Mostrar:" style="-fx-text-fill:#E6ECF2; -fx-font-size:15px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotalUsuarios" text="#"
                           style="-fx-background-color:#BFC8D4; -fx-background-radius:8; -fx-padding:6 12; -fx-text-fill:#13273B; -fx-font-weight:bold;"/>
                    <Label text="usuarios" style="-fx-text-fill:#E6ECF2; -fx-font-size:15px; -fx-font-weight:bold;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Buscar:" style="-fx-text-fill:#E6ECF2; -fx-font-size:15px; -fx-font-weight:bold;"/>

                    <TextField fx:id="tfBuscarUsuario"
                               promptText="Escribe nombre o identificación…"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#E1E7EE; -fx-background-radius:10; -fx-padding:10 94; -fx-font-size:14px;"/>

                    <Button fx:id="btnFiltrar" text="Filtrar" onAction="#onFiltrar"
                            style="-fx-background-color:#607489; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                    <Button fx:id="btnBuscar" text="Buscar" onAction="#onBuscar"
                            style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                    <Button fx:id="btnLimpiar" text="Limpiar" onAction="#onLimpiar"
                            style="-fx-background-color:#FFFFFF; -fx-text-fill:dark; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                </HBox>
            </AnchorPane>

            <!-- Tabla con scroll H/V real -->
            <AnchorPane style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:16;">
                <ScrollPane fx:id="scrollTabla"
                            fitToHeight="true" fitToWidth="false"
                            vbarPolicy="ALWAYS" hbarPolicy="ALWAYS"
                            style="-fx-background-color:transparent; -fx-background-insets:0;"
                            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="46.0"
                            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <content>
                        <VBox fx:id="tableWrapper" spacing="8" prefWidth="2500.0" style="-fx-background-color:white;">
                            <TableView fx:id="tblUsuarios" prefWidth="1750.0" prefHeight="540.0"
                                       style="-fx-font-size:14px; -fx-table-cell-border-color:#D7DBE2; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                                <columns>
                                    <TableColumn fx:id="colId"          text="ID"           prefWidth="277.0"/>
                                    <TableColumn fx:id="colCC"          text="CC"           prefWidth="277.0"/>
                                    <TableColumn fx:id="colNombre"      text="Nombre"       prefWidth="277.0"/>
                                    <TableColumn fx:id="colApellidos"   text="Apellidos"    prefWidth="277.0"/>
                                    <TableColumn fx:id="colUsuario"     text="Usuario"      prefWidth="277.0"/>
                                    <TableColumn fx:id="colEmail"       text="Email"        prefWidth="277.0"/>
                                    <TableColumn fx:id="colTelefono"    text="Teléfono"     prefWidth="277.0"/>
                                    <TableColumn fx:id="colDireccion"   text="Dirección"    prefWidth="277.0"/>
                                    <TableColumn fx:id="colPermisos"    text="Permisos"     prefWidth="275.0"/>
                                </columns>
                                <placeholder>
                                    <Label text="Sin resultados. Ajusta los filtros o realiza una búsqueda."
                                           style="-fx-text-fill:#607489; -fx-font-size:13px;"/>
                                </placeholder>
                            </TableView>

                            <Label text="Consejo: usa el cuadro de búsqueda para filtrar por nombre o identificación."
                                   style="-fx-text-fill:#6A7C90; -fx-font-size:12px; -fx-padding:6 2 0 2;"/>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Botones (no tapan la barra H) -->
                <HBox spacing="12" AnchorPane.rightAnchor="8.0" AnchorPane.bottomAnchor="8.0">
                    <Button fx:id="btnDeshacer" text="Deshacer" onAction="#onDeshacer"
                            style="-fx-background-color:#7A91A7; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                    <Button fx:id="btnEditarSeleccion" text="Editar" onAction="#onEditar"
                            style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                    <Button fx:id="btnEliminarSeleccion" text="Eliminar" onAction="#onEliminar"
                            style="-fx-background-color:#E45858; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 14; -fx-font-size:12px;"/>
                </HBox>
            </AnchorPane>
        </VBox>
    </AnchorPane>
</AnchorPane>
