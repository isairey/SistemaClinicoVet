<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upb.veterinaria.controllers.ControllerAddSurgicalProcedure.SurgicalProcedureAdd"
            fx:id="root"
            prefHeight="1000.0" prefWidth="992.0"
            style="-fx-background-color:#DFD6D6;">

    <!-- Barra superior -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          prefHeight="70.0"
          style="-fx-background-color:#FFFFFF;"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets left="18" right="18"/></padding>

        <ImageView fx:id="topLogo" onMouseClicked="#onLogoClick"
                   fitHeight="150.0" fitWidth="150.0" preserveRatio="true" pickOnBounds="true">
            <image><Image url="@../../images/logoPrincipal.png"/></image>
        </ImageView>

        <Region HBox.hgrow="ALWAYS"/>

        <MenuButton fx:id="mbNotificaciones" text="🔔"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miVerNotificaciones" text="Ver notificaciones" onAction="#onVerNotificaciones"/>
            </items>
        </MenuButton>

        <MenuButton fx:id="mbPerfil" text="👤"
                    style="-fx-background-color:transparent; -fx-font-size:23px; -fx-padding:6 10; -fx-text-fill:#113051;">
            <items>
                <MenuItem fx:id="miDatosPersonales" text="Datos personales" onAction="#onDatosPersonales"/>
                <MenuItem fx:id="miCerrarSesion"   text="Cerrar sesión"    onAction="#onCerrarSesion"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- Menú superior -->
    <HBox alignment="CENTER" spacing="32"
          layoutY="70.0" prefHeight="100.0"
          style="-fx-background-color:#113051;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnRegistrarProductos" text="Registrar Productos" onAction="#onRegistrarProductos"
                prefHeight="36.0" minWidth="160.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnInventario" text="Inventario" onAction="#onInventario"
                prefHeight="36.0" minWidth="130.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnGestionarUsuario" text="Gestionar Usuario" onAction="#onGestionarUsuario"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVisualizarRegistros" text="Visualizar Registros" onAction="#onVisualizarRegistros"
                prefHeight="36.0" minWidth="165.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnVentas" text="Ventas" onAction="#onVentas"
                prefHeight="36.0" minWidth="100.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAgregarClientes" text="Agregar Clientes" onAction="#onAgregarClientes"
                prefHeight="36.0" minWidth="150.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
        <Button fx:id="btnAdministrarProveedores" text="Administrar Proveedores" onAction="#onAdministrarProveedores"
                prefHeight="36.0" minWidth="200.0"
                style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 12;"/>
    </HBox>

    <!-- Contenido central -->
    <AnchorPane AnchorPane.topAnchor="205.0"
                AnchorPane.bottomAnchor="20.0"
                AnchorPane.leftAnchor="26.0"
                AnchorPane.rightAnchor="26.0"
                style="-fx-background-color:#173751; -fx-background-radius:18;
                       -fx-border-color:#2E3F52; -fx-border-width:5; -fx-border-radius:18;">
        <padding><Insets top="0" right="22" bottom="0" left="22"/></padding>

        <VBox spacing="18" AnchorPane.topAnchor="18.0" AnchorPane.leftAnchor="18.0"
              AnchorPane.rightAnchor="18.0" AnchorPane.bottomAnchor="18.0">

            <!-- Título -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="Añadir Servicios"
                       style="-fx-text-fill:#E9EEF3; -fx-font-size:32px; -fx-font-weight:bold;"/>
                <Label text="Busca y selecciona los servicios que deseas agregar."
                       wrapText="true"
                       style="-fx-text-fill:#B9C6D3; -fx-font-size:13px;"/>
            </VBox>

            <!-- Búsqueda -->
            <AnchorPane style="-fx-background-color:#3E566D; -fx-background-radius:12; -fx-padding:14;">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0">
                    <Label text="Buscar:" style="-fx-text-fill:#E6ECF2; -fx-font-size:15px; -fx-font-weight:bold;"/>
                    <TextField fx:id="tfBuscar" HBox.hgrow="ALWAYS"
                               promptText="Escribe ID, nombre, precio o descripción del servicio…"
                               style="-fx-background-color:#E1E7EE; -fx-background-radius:10; -fx-padding:10 14; -fx-font-size:14px;"/>
                    <Button fx:id="btnFiltrar" text="Filtrar" onAction="#onFiltrar"
                            style="-fx-background-color:#607489; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                    <Button fx:id="btnBuscar" text="Buscar" onAction="#onBuscar"
                            style="-fx-background-color:#0FB9BA; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                    <Button fx:id="btnLimpiar" text="Limpiar" onAction="#onLimpiar"
                            style="-fx-background-color:#B6C2CF; -fx-text-fill:#13273B; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                </HBox>
            </AnchorPane>

            <!-- Dos columnas -->
            <HBox spacing="18">

                <!-- IZQUIERDA: Servicios disponibles -->
                <AnchorPane HBox.hgrow="ALWAYS"
                            style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:16;">
                    <VBox spacing="8"
                          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
                          AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

                        <Label text="Servicios disponibles"
                               style="-fx-text-fill:#1F2D3C; -fx-font-size:16px; -fx-font-weight:bold;"/>

                        <ScrollPane fx:id="scrollDisponibles"
                                    fitToWidth="false" fitToHeight="true"
                                    vbarPolicy="ALWAYS" hbarPolicy="ALWAYS"
                                    style="-fx-background-color:transparent; -fx-background-insets:0;"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="wrapperDisponibles" spacing="8" style="-fx-background-color:white;" prefWidth="1400.0">
                                    <TableView fx:id="tblServiciosDisponibles" prefHeight="380.0" prefWidth="1400.0"
                                               style="-fx-font-size:14px; -fx-table-cell-border-color:#D7DBE2; -fx-border-color:#D7DBE2; -fx-border-radius:10; -fx-background-radius:10;">
                                        <columns>
                                            <TableColumn fx:id="colDispId"          text="ID"                   prefWidth="120.0"/>
                                            <TableColumn fx:id="colDispNombre"      text="Nombre del Servicio"  prefWidth="380.0"/>
                                            <TableColumn fx:id="colDispPrecio"      text="Precio"               prefWidth="195.0"/>
                                            <TableColumn fx:id="colDispDescripcion" text="Descripción"          prefWidth="700.0"/>
                                        </columns>
                                        <placeholder>
                                            <Label text="Sin resultados. Ajusta los filtros o realiza una búsqueda."
                                                   style="-fx-text-fill:#607489; -fx-font-size:13px;"/>
                                        </placeholder>
                                    </TableView>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="btnSeleccionarServicio" text="Seleccionar servicio" onAction="#onSeleccionarServicio"
                                    style="-fx-background-color:#16324A; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                        </HBox>
                    </VBox>
                </AnchorPane>

                <!-- DERECHA: Seleccionados + descripción -->
                <AnchorPane HBox.hgrow="ALWAYS"
                            style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:16;">
                    <VBox spacing="10"
                          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
                          AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#EDEDED; -fx-background-radius:10; -fx-padding:8 12; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                                <Label text="Cliente:" style="-fx-text-fill:#1F2D3C; -fx-font-weight:bold;"/>
                                <Label fx:id="lbCliente" text="N/A" style="-fx-text-fill:#1F2D3C;"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#EDEDED; -fx-background-radius:10; -fx-padding:8 12; -fx-border-color:#D7DBE2; -fx-border-radius:10;">
                                <Label text="Mascota:" style="-fx-text-fill:#1F2D3C; -fx-font-weight:bold;"/>
                                <Label fx:id="lbMascota" text="N/A" style="-fx-text-fill:#1F2D3C;"/>
                            </HBox>

                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnLimpiarSeleccion" text="Limpiar selección" onAction="#onLimpiarSeleccion"
                                    style="-fx-background-color:#B6C2CF; -fx-text-fill:#13273B; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:8 16;"/>
                        </HBox>

                        <ScrollPane fx:id="scrollSeleccionados"
                                    fitToWidth="false" fitToHeight="true"
                                    vbarPolicy="ALWAYS" hbarPolicy="ALWAYS"
                                    style="-fx-background-color:transparent; -fx-background-insets:0;"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="wrapperSeleccionados" spacing="8" style="-fx-background-color:white;" prefWidth="1400.0">
                                    <TableView fx:id="tblServiciosSeleccionados" prefHeight="260.0" prefWidth="1400.0"
                                               style="-fx-font-size:14px; -fx-table-cell-border-color:#D7DBE2; -fx-border-color:#D7DBE2; -fx-border-radius:10; -fx-background-radius:10;">
                                        <columns>
                                            <TableColumn fx:id="colSelId"          text="ID"                  prefWidth="120.0"/>
                                            <TableColumn fx:id="colSelNombre"      text="Nombre del Servicio" prefWidth="380.0"/>
                                            <TableColumn fx:id="colSelPrecio"      text="Precio"              prefWidth="195.0"/>
                                            <TableColumn fx:id="colSelDescripcion" text="Descripción"         prefWidth="700.0"/>
                                        </columns>
                                        <placeholder>
                                            <Label text="Aún no hay servicios seleccionados."
                                                   style="-fx-text-fill:#607489; -fx-font-size:13px;"/>
                                        </placeholder>
                                    </TableView>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <Label text="Observaciones Adicionales"
                               style="-fx-text-fill:#1F2D3C; -fx-font-size:15px; -fx-font-weight:bold;"/>
                        <TextArea fx:id="taDescripcion" prefRowCount="6" wrapText="true"
                                  style="-fx-background-color:#FFFFFF; -fx-background-radius:12; -fx-padding:10;"/>

                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar"
                                    style="-fx-background-color:#1f8c6f; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:10 18;"/>
                        </HBox>
                    </VBox>
                </AnchorPane>
            </HBox>
        </VBox>

        <!-- Botón Volver en primer plano -->
        <Button fx:id="btnVolver" text="← Volver" onAction="#onVolver"
                style="-fx-background-color:#E6DEDE; -fx-text-fill:#1C2A3A; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:6 14;"
                AnchorPane.topAnchor="12.0" AnchorPane.leftAnchor="12.0"/>
    </AnchorPane>
</AnchorPane>
