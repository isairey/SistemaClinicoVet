# ===================================================
# Variables de Entorno - SOS Veterinaria
# Environment Variables - SOS Veterinaria
# ===================================================
#
# Copia este archivo como .env y completa los valores.
# Copy this file as .env and fill in the values.
#
# ⚠️ NUNCA subas el archivo .env al repositorio.
# ⚠️ NEVER push the .env file to the repository.
# ===================================================

# --- Base de Datos / Database ---
DB_JDBC_URL=jdbc:postgresql://localhost:5432/postgres?currentSchema=veterinaria
DB_USER=
DB_PASS=

# --- Email (SMTP - Gmail por defecto / Gmail by default) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASS=
EMAIL_FROM_NAME=SOS Veterinaria
